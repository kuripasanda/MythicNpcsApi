{
  "schemaVersion": 1,
  "id": "mythicnpcsapi",
  "version": "${version}",
  "name": "MythicNpcsApi",
  "description": "",
  "authors": [],
  "contact": {},
  "license": "GPL-3.0",
  "icon": "assets/mythicnpcsapi/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [],
    "main": [
      {
        "value": "com.github.kuripasanda.mythicnpcsapi.MythicNpcsApiEntry",
        "adapter": "kotlin"
      }
    ]
  },
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/server/MinecraftServer": ["com/github/kuripasanda/mythicnpcsapi/MinecraftServerBridge"]
    }
  },
  "mixins": [
    "mythicnpcsapi.mixins.json",
    {
      "config": "mythicnpcsapi.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
